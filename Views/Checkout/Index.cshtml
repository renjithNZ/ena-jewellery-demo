@model EnaStore.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="checkout-section py-5">
    <div class="container">
        <h1 class="section-title mb-4">Checkout</h1>

        <form asp-controller="Checkout" asp-action="Index" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-4">

                <!-- LEFT: FORM -->
                <div class="col-lg-7">

                    <!-- SHIPPING ADDRESS -->
                    <div class="checkout-card mb-4">
                        <div class="checkout-section-title">Shipping Address</div>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label">First Name</label>
                                <input asp-for="FirstName" class="form-control" placeholder="Priya">
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Last Name</label>
                                <input asp-for="LastName" class="form-control" placeholder="Sharma">
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" placeholder="priya@example.com">
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Phone</label>
                                <input asp-for="Phone" class="form-control" placeholder="+91 9876543210">
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Address</label>
                                <input asp-for="Address" class="form-control" placeholder="123 Main Street, Flat 4B">
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                            <div class="col-4">
                                <label class="form-label">City</label>
                                <input asp-for="City" class="form-control" placeholder="Sydney">
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                            <div class="col-4">
                                <label class="form-label">Postal Code</label>
                                <input asp-for="PostalCode" class="form-control" placeholder="2000">
                                <span asp-validation-for="PostalCode" class="text-danger small"></span>
                            </div>
                            <div class="col-4">
                                <label class="form-label">Country</label>
                                <select asp-for="Country" class="form-select">
                                    <option value="Australia">Australia</option>
                                    <option value="United Kingdom">United Kingdom</option>
                                    <option value="United States">United States</option>
                                    <option value="New Zealand">New Zealand</option>
                                    <option value="UAE">UAE</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- SHIPPING METHOD -->
                    <div class="checkout-card mb-4">
                        <div class="checkout-section-title">Shipping Method</div>
                        <div class="d-flex flex-column gap-2">
                            <label class="d-flex align-items-center gap-3 p-3 rounded" style="border:1.5px solid var(--border);cursor:pointer">
                                <input type="radio" asp-for="ShippingMethod" value="standard" class="form-check-input mt-0">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold" style="font-size:14px">Standard Shipping</div>
                                    <div class="text-muted" style="font-size:12px">5–7 business days</div>
                                </div>
                                <div class="fw-bold">
                                    @(Model.Subtotal >= 250 ? "Free" : "$12")
                                </div>
                            </label>
                            <label class="d-flex align-items-center gap-3 p-3 rounded" style="border:1.5px solid var(--border);cursor:pointer">
                                <input type="radio" asp-for="ShippingMethod" value="express" class="form-check-input mt-0">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold" style="font-size:14px">Express Shipping</div>
                                    <div class="text-muted" style="font-size:12px">2–3 business days</div>
                                </div>
                                <div class="fw-bold">$20</div>
                            </label>
                        </div>
                    </div>

                    <!-- PAYMENT -->
                    <div class="checkout-card">
                        <div class="checkout-section-title">Payment Details (Simulated)</div>
                        <div class="payment-sim-note">
                            💡 <strong>Demo mode:</strong> Enter any card details to simulate a successful payment.
                            To test a declined payment, use a card number starting with <strong>0000</strong>.
                        </div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Name on Card</label>
                                <input asp-for="CardName" class="form-control" placeholder="Priya Sharma">
                                <span asp-validation-for="CardName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Card Number</label>
                                <input asp-for="CardNumber" class="form-control" placeholder="4242 4242 4242 4242" maxlength="19">
                                <span asp-validation-for="CardNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Expiry (MM/YY)</label>
                                <input asp-for="CardExpiry" class="form-control" placeholder="12/28" maxlength="5">
                                <span asp-validation-for="CardExpiry" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label">CVC</label>
                                <input asp-for="CardCvc" class="form-control" placeholder="123" maxlength="4">
                                <span asp-validation-for="CardCvc" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: ORDER SUMMARY -->
                <div class="col-lg-5">
                    <div class="order-summary-card" style="position:sticky;top:80px">
                        <h5 class="mb-4" style="font-size:1.1rem">Order Summary</h5>

                        @foreach (var item in Model.Items)
                        {
                            <div class="d-flex gap-3 mb-3 pb-3" style="border-bottom:1px solid var(--border)">
                                <img src="@item.ImageUrl" alt="@item.ProductName"
                                     style="width:56px;height:70px;object-fit:cover;border-radius:4px;flex-shrink:0">
                                <div class="flex-grow-1">
                                    <div style="font-size:13px;font-weight:600">@item.ProductName</div>
                                    @if (!string.IsNullOrEmpty(item.SelectedSize))
                                    {
                                        <div class="text-muted" style="font-size:11px">Size: @item.SelectedSize</div>
                                    }
                                    @if (!string.IsNullOrEmpty(item.SelectedMetal))
                                    {
                                        <div class="text-muted" style="font-size:11px">Metal: @item.SelectedMetal</div>
                                    }
                                    <div style="font-size:12px;color:var(--muted)">Qty: @item.Quantity</div>
                                </div>
                                <div style="font-size:14px;font-weight:700;white-space:nowrap">$@item.LineTotal.ToString("N0")</div>
                            </div>
                        }

                        <!-- COUPON -->
                        <div class="mb-3">
                            <label class="form-label" style="font-size:12px">Coupon Code</label>
                            <div class="input-group">
                                <input asp-for="CouponCode" class="form-control form-control-sm" placeholder="ENA10">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Apply</button>
                            </div>
                        </div>

                        <hr>
                        <div class="d-flex justify-content-between mb-1">
                            <span style="font-size:14px">Subtotal</span>
                            <span>$@Model.Subtotal.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span style="font-size:14px">Shipping</span>
                            <span id="shippingDisplay">$@Model.ShippingCost.ToString("N0")</span>
                        </div>
                        @if (Model.Discount > 0)
                        {
                            <div class="d-flex justify-content-between mb-1 text-success">
                                <span style="font-size:14px">Discount</span>
                                <span>-$@Model.Discount.ToString("N0")</span>
                            </div>
                        }
                        <hr>
                        <div class="d-flex justify-content-between fw-bold mb-4">
                            <span>Total</span>
                            <span style="font-size:1.2rem">$@Model.Total.ToString("N0")</span>
                        </div>

                        <button type="submit" class="btn-gold d-block w-100 text-center" style="padding:16px;font-size:13px">
                            Place Order →
                        </button>
                        <div class="text-center mt-2" style="font-size:11px;color:var(--muted)">
                            🔒 Simulated payment — no real charge
                        </div>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
