@model EnaStore.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="confirmation-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7 text-center">

                <div class="confirmation-icon mb-3">✅</div>
                <h1 class="section-title" style="font-size:2.2rem">Order Confirmed!</h1>
                <p class="text-muted mb-4">
                    Thank you, <strong>@Model.CustomerName</strong>! Your order has been placed successfully.
                    A confirmation would be sent to <strong>@Model.CustomerEmail</strong>.
                </p>

                <!-- ORDER CARD -->
                <div class="checkout-card text-start mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <div class="section-eyebrow mb-0">Order ID</div>
                            <h4 style="font-size:1.2rem">@Model.OrderId</h4>
                        </div>
                        <div>
                            <span class="status-badge status-@Model.Status">@Model.Status</span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="text-muted" style="font-size:11px;letter-spacing:1px;text-transform:uppercase">Placed On</div>
                            <div style="font-size:14px;font-weight:600">@Model.PlacedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted" style="font-size:11px;letter-spacing:1px;text-transform:uppercase">Payment</div>
                            <div style="font-size:14px;font-weight:600;color:#2e7d32">✅ @Model.PaymentStatus</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted" style="font-size:11px;letter-spacing:1px;text-transform:uppercase">Shipping</div>
                            <div style="font-size:14px;font-weight:600">@(Model.ShippingMethod == "express" ? "Express (2-3 days)" : "Standard (5-7 days)")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted" style="font-size:11px;letter-spacing:1px;text-transform:uppercase">Ship To</div>
                            <div style="font-size:13px">@Model.ShippingAddress</div>
                        </div>
                    </div>

                    <hr style="border-color:var(--border)">

                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex gap-3 mb-3">
                            <img src="@item.ImageUrl" alt="@item.ProductName"
                                 style="width:56px;height:70px;object-fit:cover;border-radius:4px;flex-shrink:0;background:var(--warm-gray)">
                            <div class="flex-grow-1">
                                <div style="font-size:14px;font-weight:600">@item.ProductName</div>
                                @if (!string.IsNullOrEmpty(item.SelectedSize))
                                {
                                    <div class="text-muted" style="font-size:12px">Size: @item.SelectedSize</div>
                                }
                                @if (!string.IsNullOrEmpty(item.SelectedMetal))
                                {
                                    <div class="text-muted" style="font-size:12px">Metal: @item.SelectedMetal</div>
                                }
                                <div class="text-muted" style="font-size:12px">Qty: @item.Quantity</div>
                            </div>
                            <div style="font-weight:700;white-space:nowrap">$@item.LineTotal.ToString("N0")</div>
                        </div>
                    }

                    <hr style="border-color:var(--border)">
                    <div class="d-flex justify-content-between fw-bold" style="font-size:1.1rem">
                        <span>Total Paid</span>
                        <span>$@Model.Total.ToString("N0")</span>
                    </div>
                </div>

                <!-- WHAT'S NEXT -->
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a asp-controller="Shop" asp-action="Index" class="btn-gold">Continue Shopping</a>
                    <a asp-controller="Home" asp-action="Index" class="btn-outline-gold">Back to Home</a>
                </div>

                <div class="mt-4 text-muted" style="font-size:13px">
                    <strong>Demo note:</strong> This is a simulated order. No real payment was processed.
                </div>
            </div>
        </div>
    </div>
</div>
