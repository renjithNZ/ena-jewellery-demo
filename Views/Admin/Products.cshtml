@model List<EnaStore.Models.Product>
@{
    ViewData["Title"] = "Admin — Products";
}

<div class="admin-header">
    <div class="container d-flex justify-content-between align-items-center">
        <h4>Products</h4>
        <div class="d-flex gap-3">
            <a asp-controller="Admin" asp-action="Index" class="btn-outline-gold" style="padding:8px 20px;font-size:12px;color:#e8d48b;border-color:#e8d48b">Dashboard</a>
            <a asp-controller="Admin" asp-action="Orders" class="btn-outline-gold" style="padding:8px 20px;font-size:12px;color:#e8d48b;border-color:#e8d48b">Orders</a>
        </div>
    </div>
</div>

<div class="container pb-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 style="font-size:1.3rem;margin-bottom:4px">All Products</h3>
            <span class="text-muted" style="font-size:13px">@Model.Count products total</span>
        </div>
        <!-- Filter tabs -->
        <div class="d-flex gap-2">
            @{
                var cats = new[] { "all", "rings", "necklaces", "earrings", "bracelets" };
                foreach (var cat in cats)
                {
                    <a href="#@cat" onclick="filterProducts('@cat');return false;"
                       class="btn btn-sm btn-outline-secondary filter-tab" data-cat="@cat"
                       style="font-size:12px;letter-spacing:1px">
                        @(cat == "all" ? "All" : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(cat))
                    </a>
                }
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table" id="productsTable">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Update Stock</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr data-cat="@p.Category">
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="@p.ImageUrl" alt="@p.Name"
                                     style="width:48px;height:60px;object-fit:cover;border-radius:4px;flex-shrink:0;background:var(--warm-gray)">
                                <div>
                                    <div style="font-weight:600;font-size:14px">@p.Name</div>
                                    <div class="text-muted" style="font-size:11px">@p.Material</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span style="font-size:12px;background:var(--warm-gray);padding:3px 10px;border-radius:10px">
                                @System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(p.Category)
                            </span>
                        </td>
                        <td style="font-weight:700">$@p.Price.ToString("N0")</td>
                        <td>
                            <span style="font-weight:700;color:@(p.StockCount < 6 ? "#f57f17" : "var(--dark)")">
                                @p.StockCount
                            </span>
                            @if (p.StockCount < 6)
                            {
                                <span style="font-size:10px;color:#f57f17;margin-left:4px">⚠ Low</span>
                            }
                        </td>
                        <td>
                            @if (p.InStock)
                            {
                                <span class="status-badge status-Paid">In Stock</span>
                            }
                            else
                            {
                                <span class="status-badge status-Cancelled">Out of Stock</span>
                            }
                        </td>
                        <td>
                            <form asp-controller="Admin" asp-action="UpdateStock" method="post" class="d-flex gap-2 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@p.Id">
                                <input type="number" name="stock" value="@p.StockCount" min="0" max="999"
                                       class="form-control form-control-sm" style="width:70px">
                                <button type="submit" class="btn btn-sm btn-outline-secondary" style="font-size:12px;white-space:nowrap">Update</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    function filterProducts(cat) {
        document.querySelectorAll('#productsTable tbody tr').forEach(row => {
            row.style.display = (cat === 'all' || row.dataset.cat === cat) ? '' : 'none';
        });
        document.querySelectorAll('.filter-tab').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.cat === cat);
        });
    }
</script>
}
