@model List<EnaStore.Models.Order>
@{
    ViewData["Title"] = "Admin — Orders";
}

<div class="admin-header">
    <div class="container d-flex justify-content-between align-items-center">
        <h4>Orders</h4>
        <div class="d-flex gap-3">
            <a asp-controller="Admin" asp-action="Index" class="btn-outline-gold" style="padding:8px 20px;font-size:12px;color:#e8d48b;border-color:#e8d48b">Dashboard</a>
            <a asp-controller="Admin" asp-action="Products" class="btn-outline-gold" style="padding:8px 20px;font-size:12px;color:#e8d48b;border-color:#e8d48b">Products</a>
        </div>
    </div>
</div>

<div class="container pb-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 style="font-size:1.3rem;margin-bottom:4px">All Orders</h3>
            <span class="text-muted" style="font-size:13px">@Model.Count orders total</span>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @{
                var statuses = new[] { "all", "Placed", "Paid", "Processing", "Shipped", "Delivered", "Cancelled" };
                foreach (var s in statuses)
                {
                    <a href="#" onclick="filterOrders('@s');return false;"
                       class="btn btn-sm btn-outline-secondary status-filter" data-status="@s"
                       style="font-size:11px">@s</a>
                }
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:48px">📦</div>
            <h4 class="mt-3">No orders yet</h4>
            <p class="text-muted">Place a test order from the storefront.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn-gold">Go to Store</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table admin-table" id="ordersTable">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Products</th>
                        <th>Total</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th>Update Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr data-status="@order.Status">
                            <td><code style="font-size:11px">@order.OrderId</code></td>
                            <td>
                                <div style="font-weight:600;font-size:13px">@order.CustomerName</div>
                                <div class="text-muted" style="font-size:11px">@order.CustomerEmail</div>
                            </td>
                            <td style="font-size:12px">@order.PlacedAt.ToLocalTime().ToString("dd MMM yy, HH:mm")</td>
                            <td>
                                @foreach (var item in order.Items.Take(2))
                                {
                                    <div style="font-size:12px">@item.ProductName × @item.Quantity</div>
                                }
                                @if (order.Items.Count > 2)
                                {
                                    <div class="text-muted" style="font-size:11px">+@(order.Items.Count - 2) more</div>
                                }
                            </td>
                            <td style="font-weight:700">$@order.Total.ToString("N0")</td>
                            <td>
                                <span class="status-badge" style="background:#e8f5e9;color:#2e7d32">@order.PaymentStatus</span>
                            </td>
                            <td><span class="status-badge status-@order.Status">@order.Status</span></td>
                            <td>
                                <form asp-controller="Admin" asp-action="UpdateOrderStatus" method="post" class="d-flex gap-2 align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.OrderId">
                                    <select name="status" class="form-select form-select-sm" style="font-size:12px;min-width:110px">
                                        @foreach (var s in new[] { "Placed", "Paid", "Processing", "Shipped", "Delivered", "Cancelled" })
                                        {
                                            if (order.Status == s)
                                            {
                                                <option value="@s" selected>@s</option>
                                            }
                                            else
                                            {
                                                <option value="@s">@s</option>
                                            }
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" style="font-size:11px;white-space:nowrap">Save</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
    function filterOrders(status) {
        document.querySelectorAll('#ordersTable tbody tr').forEach(row => {
            row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
        });
        document.querySelectorAll('.status-filter').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.status === status);
        });
    }
</script>
}
