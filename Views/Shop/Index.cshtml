@model List<EnaStore.Models.Product>
@{
    ViewData["Title"] = "Collections";
    var currentCategory = ViewBag.CurrentCategory as string ?? "all";
    var currentSort = ViewBag.CurrentSort as string ?? "";
    var categories = ViewBag.Categories as string[] ?? Array.Empty<string>();
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
}

<div class="container py-5">
    <div class="row g-5">

        <!-- SIDEBAR FILTERS -->
        <div class="col-lg-2">
            <div class="shop-sidebar">
                <div class="filter-heading">Category</div>
                @foreach (var cat in categories)
                {
                    <a asp-controller="Shop" asp-action="Index"
                       asp-route-category="@cat"
                       asp-route-sort="@currentSort"
                       class="category-filter-btn @(currentCategory == cat ? "active" : "")">
                        @(cat == "all" ? "All Jewellery" : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(cat))
                    </a>
                }

                <div class="filter-heading mt-4">Sort By</div>
                @{
                    var sorts = new[] {
                        ("", "Featured"),
                        ("price-asc", "Price: Low to High"),
                        ("price-desc", "Price: High to Low"),
                        ("rating", "Top Rated")
                    };
                }
                @foreach (var (val, label) in sorts)
                {
                    <a asp-controller="Shop" asp-action="Index"
                       asp-route-category="@currentCategory"
                       asp-route-sort="@val"
                       class="category-filter-btn @(currentSort == val ? "active" : "")">
                        @label
                    </a>
                }
            </div>
        </div>

        <!-- PRODUCT GRID -->
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="section-title mb-1" style="font-size:1.8rem">
                        @(currentCategory == "all" ? "All Jewellery" : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(currentCategory))
                    </h1>
                    <span class="text-muted" style="font-size:13px">@totalCount pieces</span>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div style="font-size:48px">💎</div>
                    <h4 class="mt-3">No products found</h4>
                    <p class="text-muted">Try a different filter.</p>
                    <a asp-controller="Shop" asp-action="Index" class="btn-gold">View All</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var p in Model)
                    {
                        <div class="col-6 col-md-4 col-xl-3">
                            <div class="product-card">
                                @if (p.IsBestseller)
                                {
                                    <span class="product-badge bestseller">Bestseller</span>
                                }
                                else if (p.IsFeatured)
                                {
                                    <span class="product-badge">Featured</span>
                                }
                                @if (!p.InStock)
                                {
                                    <span class="product-badge" style="right:10px;left:auto;background:#ccc;color:#555">Sold Out</span>
                                }
                                <a asp-controller="Shop" asp-action="Details" asp-route-slug="@p.Slug">
                                    <div class="product-card-img">
                                        <img src="@p.ImageUrl" alt="@p.Name" loading="lazy">
                                    </div>
                                </a>
                                <div class="product-category">@p.Category</div>
                                <h6>
                                    <a asp-controller="Shop" asp-action="Details" asp-route-slug="@p.Slug">@p.Name</a>
                                </h6>
                                <div class="star-rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        @(i <= Math.Round(p.Rating) ? "★" : "☆")
                                    }
                                    <span class="text-muted ms-1" style="font-size:11px">(@p.ReviewCount)</span>
                                </div>
                                <div class="product-price mt-1">$@p.Price.ToString("N0")</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
